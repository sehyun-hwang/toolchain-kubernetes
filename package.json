{
  "name": "tsed",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build": "barrels && swc src --out-dir dist -s  --strip-leading-paths",
    "start": "barrels && node --enable-source-maps --import @swc-node/register/esm-register --watch src/index.ts",
    "start.prod": "NODE_ENV=production node dist/index.js",
    "test.unit": "NODE_ENV=test vitest run",
    "test.watch": "NODE_ENV=test vitest",
    "test.coverage": "NODE_ENV=test vitest run --coverage"
  },
  "dependencies": {
    "@swc-node/register": "^1.10.9",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.8",
    "@swc/helpers": "^0.5.15",
    "@tsed/ajv": "^8.5.4",
    "@tsed/barrels": "^6.2.0",
    "@tsed/core": "^8.5.4",
    "@tsed/di": "^8.5.4",
    "@tsed/engines": "^8.5.4",
    "@tsed/exceptions": "^8.5.4",
    "@tsed/json-mapper": "^8.5.4",
    "@tsed/logger": "^7.0.1",
    "@tsed/openspec": "^8.5.4",
    "@tsed/platform-cache": "^8.5.4",
    "@tsed/platform-exceptions": "^8.5.4",
    "@tsed/platform-express": "^8.5.4",
    "@tsed/platform-http": "^8.5.4",
    "@tsed/platform-log-request": "^8.5.4",
    "@tsed/platform-middlewares": "^8.5.4",
    "@tsed/platform-params": "^8.5.4",
    "@tsed/platform-response-filter": "^8.5.4",
    "@tsed/platform-views": "^8.5.4",
    "@tsed/schema": "^8.5.4",
    "ajv": "^8.17.1",
    "body-parser": "^1.20.3",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^12.0.1",
    "dotenv-flow": "^4.1.0",
    "express": "^4.21.2",
    "method-override": "^3.0.0",
    "pg": "^8.14.0",
    "typeorm": "^0.3.21",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@tsed/cli-plugin-typeorm": "6.2.0",
    "@tsed/cli-plugin-vitest": "6.2.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/method-override": "^3.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.8",
    "supertest": "^7.0.0",
    "tslib": "^2.8.1",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.8"
  },
  "tsed": {
    "convention": "conv_default",
    "architecture": "arc_default",
    "packageManager": "pnpm",
    "runtime": "node"
  },
  "type": "module"
}
